{
    "version": 2,
    "builds": [
        {
            "src": "backend/app.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "2048mb"  
            }
        },
        {
            "src": "frontend",
            "use": "@vercel/static-build",
            "config": {
                "framework": "vue@2",  
                "devCommand": "yarn serve",
                "outputDirectory": "dist"  
            }
        }
    ],
    "routes": [
        { "handle": "filesystem" },
        {
            "src": "/api/(.*)",
            "dest": "backend/app.py"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/index.html"
        }
    ],
    "env": {
        "MONGODB_URI": "@MONGODB_URI"
    }
}
